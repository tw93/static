name: Flower Simple Proxy
desc: Manual proxy selection for Flower. Proxy and AI Proxy each pick Hong Kong, United States, or DIRECT; HK and US sub-groups list individual nodes.
category: Proxy

profile:
  store-selected: true

dns: #!replace
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - "*.localdomain"
    - "*.home.arpa"
    - "+.cn"
    - "+.baidu.com"
    - "+.taobao.com"
    - "+.tmall.com"
    - "+.alipay.com"
    - "+.aliyun.com"
    - "+.alibaba.com"
    - "+.alibaba-inc.com"
    - "+.antfin.com"
    - "+.antfin-inc.com"
    - "+.atatech.org"
    - "+.dingtalk.com"
    - "+.qq.com"
    - "+.wechat.com"
    - "+.weixin.qq.com"
    - "+.icloud.com"
    - "+.apple.com"
    - "+.push.apple.com"
    - "+.xiaomi.com"
    - "+.mi.com"
    - "+.bilibili.com"
    - "+.163.com"
    - "+.126.com"
    - "+.netease.com"
    - "+.jd.com"
    - "+.jdcloud.com"
    - "+.360buyimg.com"
    - "+.weibo.com"
    - "+.xiaohongshu.com"
    - "+.xhscdn.com"
    - "+.douyin.com"
    - "+.douyinpic.com"
    - "+.bytedance.com"
    - "+.toutiao.com"
    - "+.snssdk.com"
    - "+.meituan.com"
    - "+.meituan.net"
    - "+.dianping.com"
    - "+.kuaishou.com"
    - "+.gifshow.com"
    - "+.pinduoduo.com"
    - "+.yangkeduo.com"
    - "+.zhihu.com"
    - "+.zhimg.com"
    - "time.*.com"
    - "ntp.*.com"
    - "stun.*.*"
    - "stun.*.*.*"
  nameserver:
    - 223.5.5.5
    - 119.29.29.29
  fallback:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4

proxy-groups: #!replace
  - name: Proxy
    type: select
    proxies:
      - HK
      - US
      - DIRECT

  - name: AI Proxy
    type: select
    proxies:
      - US
      - HK
      - DIRECT

  - name: HK
    type: select
    proxies:
      - 🇭🇰 香港高级 IEPL 专线 2
      - 🇭🇰 香港标准 IEPL 专线 5
      - 🇭🇰 香港高级 IEPL 专线 1
      - 🇭🇰 香港标准 IEPL 专线 2
      - 🇭🇰 香港标准 IEPL 专线 1
      - 🇭🇰 香港标准 IEPL 专线 6
      - 🇭🇰 香港标准 IEPL 专线 4
      - 🇭🇰 香港标准 IEPL 专线 7
      - 🇭🇰 香港实验性 IEPL 专线 1
      - 🇭🇰 香港标准 IEPL 专线 3
      - 🇭🇰 香港高级 IEPL 专线 3
      - 🇭🇰 香港标准 IEPL 专线 8

  - name: US
    type: select
    proxies:
      - 🇺🇸 美国标准 IEPL 专线 8
      - 🇺🇸 美国标准 IEPL 专线 4
      - 🇺🇸 美国标准 IEPL 专线 7
      - 🇺🇸 美国标准 IEPL 专线 5
      - 🇺🇸 美国标准 IEPL 专线 3
      - 🇺🇸 美国标准 IEPL 专线 2
      - 🇺🇸 美国高级 IEPL 专线 3
      - 🇺🇸 美国标准 IEPL 专线 1
      - 🇺🇸 美国高级 IEPL 专线 1
      - 🇺🇸 美国高级 IEPL 专线 2
      - 🇺🇸 美国标准 IEPL 专线 6
      - 🇺🇸 美国实验性 IEPL 专线 1

rules: #!replace
  # === Direct ===
  - DOMAIN-SUFFIX,qoder.sh,DIRECT

  # === OpenAI / ChatGPT / Codex ===
  - DOMAIN-SUFFIX,openai.com,AI Proxy
  - DOMAIN-SUFFIX,chatgpt.com,AI Proxy
  - DOMAIN-SUFFIX,oaistatic.com,AI Proxy
  - DOMAIN-SUFFIX,oaiusercontent.com,AI Proxy
  - DOMAIN-SUFFIX,openai-cdn.com,AI Proxy
  - DOMAIN-SUFFIX,openaiapi-site.azureedge.net,AI Proxy
  - DOMAIN-SUFFIX,openaicom.imgix.net,AI Proxy
  - DOMAIN,openaicom-api-bdcpf8c6d2e9atf6.z01.azurefd.net,AI Proxy
  - DOMAIN,production-openaicom-storage.azureedge.net,AI Proxy
  - DOMAIN-SUFFIX,livekit.cloud,AI Proxy

  # === Claude / Anthropic ===
  - DOMAIN-SUFFIX,anthropic.com,AI Proxy
  - DOMAIN-SUFFIX,claude.ai,AI Proxy
  - DOMAIN-SUFFIX,claude.com,AI Proxy
  - DOMAIN-SUFFIX,claudeusercontent.com,AI Proxy
  - DOMAIN-SUFFIX,ant.dev,AI Proxy
  - DOMAIN-SUFFIX,claudeaistatus.com,AI Proxy

  # === Gemini / Google AI ===
  - DOMAIN,accounts.google.com,AI Proxy
  - DOMAIN-SUFFIX,googleapis.com,AI Proxy
  - DOMAIN-SUFFIX,deepmind.com,AI Proxy
  - DOMAIN-SUFFIX,generativeai.google,AI Proxy
  - DOMAIN,gemini.google.com,AI Proxy
  - DOMAIN,bard.google.com,AI Proxy
  - DOMAIN,aistudio.google.com,AI Proxy
  - DOMAIN,makersuite.google.com,AI Proxy
  - DOMAIN,generativelanguage.googleapis.com,AI Proxy
  - DOMAIN,ai.google.dev,AI Proxy
  - DOMAIN,notebooklm.google.com,AI Proxy
  - DOMAIN-SUFFIX,google-gemini.dev,AI Proxy
  - DOMAIN-SUFFIX,tensorflow.org,AI Proxy

  # === xAI / Groq ===
  - DOMAIN-SUFFIX,x.ai,AI Proxy
  - DOMAIN-SUFFIX,grok.com,AI Proxy
  - DOMAIN,api.x.ai,AI Proxy
  - DOMAIN-SUFFIX,groq.com,AI Proxy

  # === Coding agents and tools ===
  - DOMAIN-SUFFIX,cursor.sh,AI Proxy
  - DOMAIN-SUFFIX,cursor.com,AI Proxy
  - DOMAIN-SUFFIX,cursorapi.com,AI Proxy
  - DOMAIN-SUFFIX,cursor-cdn.com,AI Proxy
  - DOMAIN-SUFFIX,github.com,AI Proxy
  - DOMAIN-SUFFIX,githubusercontent.com,AI Proxy
  - DOMAIN-SUFFIX,githubcopilot.com,AI Proxy
  - DOMAIN-SUFFIX,copilot.github.com,AI Proxy

  # === Other AI services ===
  - DOMAIN-SUFFIX,cohere.com,AI Proxy
  - DOMAIN-SUFFIX,mistral.ai,AI Proxy
  - DOMAIN-SUFFIX,together.ai,AI Proxy
  - DOMAIN-SUFFIX,replicate.com,AI Proxy
  - DOMAIN-SUFFIX,huggingface.co,AI Proxy
  - DOMAIN-SUFFIX,perplexity.ai,AI Proxy
  - DOMAIN-SUFFIX,pplx.ai,AI Proxy
  - DOMAIN-SUFFIX,openrouter.ai,AI Proxy
  - DOMAIN-SUFFIX,windsurf.com,AI Proxy
  - DOMAIN-SUFFIX,codeium.com,AI Proxy
  - DOMAIN-SUFFIX,v0.dev,AI Proxy
  - DOMAIN-SUFFIX,bolt.new,AI Proxy
  - DOMAIN-SUFFIX,midjourney.com,AI Proxy
  - DOMAIN-SUFFIX,workers.dev,AI Proxy

  # === AI dependencies ===
  - DOMAIN-SUFFIX,stripe.com,AI Proxy
  - DOMAIN-SUFFIX,segment.io,AI Proxy
  - DOMAIN-SUFFIX,intercom.io,AI Proxy
  - DOMAIN-SUFFIX,intercomcdn.com,AI Proxy
  - DOMAIN-SUFFIX,sentry.io,AI Proxy
  - DOMAIN-SUFFIX,algolia.net,AI Proxy
  - DOMAIN-SUFFIX,statsig.com,AI Proxy
  - DOMAIN,challenges.cloudflare.com,AI Proxy
  - DOMAIN-SUFFIX,workos.com,AI Proxy
  - DOMAIN-SUFFIX,launchdarkly.com,AI Proxy
  - DOMAIN-SUFFIX,honeycomb.io,AI Proxy
  - DOMAIN-SUFFIX,datadoghq.com,AI Proxy

  # === Work / internal direct ===
  - DOMAIN-SUFFIX,antfin.com,DIRECT
  - DOMAIN-SUFFIX,antfin-inc.com,DIRECT
  - DOMAIN-SUFFIX,alibaba-inc.com,DIRECT
  - DOMAIN-SUFFIX,alibaba.com,DIRECT
  - DOMAIN-SUFFIX,alibabacorp.com,DIRECT
  - DOMAIN-SUFFIX,alibabadns.com,DIRECT
  - DOMAIN-SUFFIX,alibaba.net,DIRECT
  - DOMAIN-SUFFIX,atatech.org,DIRECT
  - DOMAIN-SUFFIX,alipay.com,DIRECT
  - DOMAIN-SUFFIX,taobao.com,DIRECT
  - DOMAIN-SUFFIX,aliyun.com,DIRECT
  - DOMAIN-SUFFIX,aliyun-inc.com,DIRECT
  - DOMAIN-SUFFIX,aliyuncs.com,DIRECT
  - DOMAIN-SUFFIX,fliggy.com,DIRECT
  - DOMAIN-SUFFIX,yuque.com,DIRECT
  - DOMAIN-SUFFIX,dingtalk.com,DIRECT
  - DOMAIN-SUFFIX,dingtalkapps.com,DIRECT
  - DOMAIN-SUFFIX,dingtalk.net,DIRECT
  - DOMAIN-SUFFIX,alicdn.com,DIRECT
  - DOMAIN-SUFFIX,aliway.com,DIRECT
  - DOMAIN-SUFFIX,antgroup.com,DIRECT
  - DOMAIN-SUFFIX,aliwork.com,DIRECT
  - DOMAIN-SUFFIX,ztna-dingtalk.com,DIRECT
  - DOMAIN-SUFFIX,aliimg.com,DIRECT
  - DOMAIN-SUFFIX,sspai.com,DIRECT

  # === Work / internal IP ranges ===
  - GEOIP,private,DIRECT,no-resolve
  - IP-CIDR,11.122.0.0/15,DIRECT,no-resolve
  - IP-CIDR,11.124.0.0/16,DIRECT,no-resolve
  - IP-CIDR,11.158.0.0/15,DIRECT,no-resolve
  - IP-CIDR,11.160.0.0/13,DIRECT,no-resolve
  - IP-CIDR,11.238.0.0/15,DIRECT,no-resolve
  - IP-CIDR,203.119.0.0/16,DIRECT,no-resolve

  # === Force Hong Kong ===
  - DOMAIN-SUFFIX,apple-relay.akamaized.net,HK
  - DOMAIN-SUFFIX,apple-relay.apple.com,HK
  - DOMAIN-SUFFIX,apple-relay.cloudflare.com,HK
  - DOMAIN-SUFFIX,apple-relay.fastly-edge.com,HK
  - DOMAIN-SUFFIX,apple-relay.mask.apple-dns.net,HK
  - DOMAIN-SUFFIX,push.apple.com,HK
  - DOMAIN-SUFFIX,api.push.apple.com,HK
  - DOMAIN-SUFFIX,courier.push.apple.com,HK
  - DOMAIN-SUFFIX,wx.qq.com,HK
  - DOMAIN-SUFFIX,v2ex.com,HK

  # === Domestic fallback ===
  - DOMAIN-SUFFIX,cn,DIRECT
  - GEOIP,CN,DIRECT

  # === Default ===
  - MATCH,Proxy
