name: Nexitally Stash Override
desc: Manual proxy selection. Proxies group lists Japan, Hong Kong, Singapore nodes; AI group lists United States Seattle nodes. Splits AI services to the AI group and keeps domestic and work traffic direct.
category: Proxy

profile:
  store-selected: true

proxy-groups: #!replace
  - name: Proxies
    type: select
    proxies:
      - 🇯🇵 Japan 01
      - 🇯🇵 Japan 02
      - 🇯🇵 Japan 03
      - 🇯🇵 Japan 04
      - 🇯🇵 Japan 05
      - 🇯🇵 Japan 06
      - 🇯🇵 Japan 07
      - 🇯🇵 Japan 08
      - 🇯🇵 Japan 09
      - 🇯🇵 Japan 10
      - 🇯🇵 Japan 11
      - 🇯🇵 Japan 12
      - 🇯🇵 Japan 13
      - 🇯🇵 Japan 14
      - 🇯🇵 Japan 15
      - 🇯🇵 Japan 16
      - 🇯🇵 Japan 17
      - 🇯🇵 Japan 18
      - 🇯🇵 Japan 19
      - 🇯🇵 Japan 20
      - 🇯🇵 Japan 21
      - 🇯🇵 Japan 24
      - 🇯🇵 Japan 25
      - 🇯🇵 Japan 26
      - 🇯🇵 Japan 27
      - 🇭🇰 Hong Kong 01
      - 🇭🇰 Hong Kong 02
      - 🇭🇰 Hong Kong 03
      - 🇭🇰 Hong Kong 04
      - 🇭🇰 Hong Kong 05
      - 🇭🇰 Hong Kong 06
      - 🇭🇰 Hong Kong 07
      - 🇭🇰 Hong Kong 08
      - 🇭🇰 Hong Kong 09
      - 🇭🇰 Hong Kong 10
      - 🇭🇰 Hong Kong 11
      - 🇭🇰 Hong Kong 12
      - 🇭🇰 Hong Kong 13
      - 🇭🇰 Hong Kong 14
      - 🇭🇰 Hong Kong 15
      - 🇭🇰 Hong Kong 16
      - 🇭🇰 Hong Kong 17
      - 🇭🇰 Hong Kong 18
      - 🇭🇰 Hong Kong 19
      - 🇭🇰 Hong Kong 23
      - 🇸🇬 Singapore 01
      - 🇸🇬 Singapore 02
      - 🇸🇬 Singapore 03
      - 🇸🇬 Singapore 04
      - 🇸🇬 Singapore 05
      - 🇸🇬 Singapore 06
      - 🇸🇬 Singapore 07
      - 🇸🇬 Singapore 08
      - 🇸🇬 Singapore 09
      - 🇸🇬 Singapore 10
      - 🇸🇬 Singapore 12

  - name: AI
    type: select
    proxies:
      - 🇺🇸 USA Seattle 01
      - 🇺🇸 USA Seattle 02
      - 🇺🇸 USA Seattle 03
      - 🇺🇸 USA Seattle 04
      - 🇺🇸 USA Seattle 05
      - 🇺🇸 USA Seattle 06
      - 🇺🇸 USA Seattle 07
      - 🇺🇸 USA Seattle 08
      - 🇺🇸 USA Seattle 09

  - name: Final
    type: select
    proxies:
      - Proxies
      - DIRECT

rules: #!replace
  # === Direct ===
  - DOMAIN-SUFFIX,qoder.sh,DIRECT

  # === OpenAI / ChatGPT / Codex ===
  - DOMAIN-SUFFIX,openai.com,AI
  - DOMAIN-SUFFIX,chatgpt.com,AI
  - DOMAIN-SUFFIX,oaistatic.com,AI
  - DOMAIN-SUFFIX,oaiusercontent.com,AI
  - DOMAIN-SUFFIX,openai-cdn.com,AI
  - DOMAIN-SUFFIX,openaiapi-site.azureedge.net,AI
  - DOMAIN-SUFFIX,openaicom.imgix.net,AI
  - DOMAIN,openaicom-api-bdcpf8c6d2e9atf6.z01.azurefd.net,AI
  - DOMAIN,production-openaicom-storage.azureedge.net,AI
  - DOMAIN-SUFFIX,livekit.cloud,AI

  # === Claude / Anthropic ===
  - DOMAIN-SUFFIX,anthropic.com,AI
  - DOMAIN-SUFFIX,claude.ai,AI
  - DOMAIN-SUFFIX,claude.com,AI
  - DOMAIN-SUFFIX,claudeusercontent.com,AI
  - DOMAIN-SUFFIX,ant.dev,AI
  - DOMAIN-SUFFIX,claudeaistatus.com,AI

  # === Gemini / Google AI ===
