name: Nexitally Stash Override
desc: Default traffic uses Hong Kong, AI traffic uses United States, with direct rules for work domains.
category: Proxy

# === Network tuning for long-lived AI streaming connections ===
keep-alive-idle: 600
keep-alive-interval: 10
connection-idle-timeout: 600
tcp-concurrent: true
unified-delay: true
disable-keep-alive: false
buffer-size: 65536
ipv6: false

hosts:
  mtalk.google.com: 108.177.125.188
  services.googleapis.cn: 74.125.203.94
  clientservices.googleapis.com: 142.250.80.42

profile:
  store-selected: true
  store-fake-ip: true
  tracing: true

dns: #!replace
  enable: true
  cache-algorithm: arc
  prefer-h3: false
  ipv6: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "*.lan"
    - "*.localdomain"
    - "*.local"
    - "*.home.arpa"
    - time.*.com
    - ntp.*.com
    - +.market.xiaomi.com
    - +.push.apple.com
    - swscan.apple.com
    - mesu.apple.com
    - stun.*.*
    - stun.*.*.*
    - +.alibaba-inc.com
    - +.antfin.com
    - +.antfin-inc.com
    - +.atatech.org
    - +.aliyun.com
    - +.taobao.com
    - +.alipay.com
    - +.alibaba.com
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
  fallback:
    - https://8.8.8.8/dns-query
    - https://1.1.1.1/dns-query
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4

proxy-groups: #!replace
  - name: Proxies
    type: select
    proxies:
      - HK
      - US
      - DIRECT

  - name: AI
    type: select
    proxies:
      - US
      - Proxies
      - HK
      - DIRECT

  - name: HK
    type: url-test
    proxies:
      - 🇭🇰 Hong Kong 09
      - 🇭🇰 Hong Kong 17
      - 🇭🇰 Hong Kong 10
      - 🇭🇰 Hong Kong 14
      - 🇭🇰 Hong Kong 11
      - 🇭🇰 Hong Kong 06
      - 🇭🇰 Hong Kong 23
      - 🇭🇰 Hong Kong 05
      - 🇭🇰 Hong Kong 08
      - 🇭🇰 Hong Kong 02
      - 🇭🇰 Hong Kong 15
      - 🇭🇰 Hong Kong 16
      - 🇭🇰 Hong Kong 01
      - 🇭🇰 Hong Kong 03
      - 🇭🇰 Hong Kong 04
      - 🇭🇰 Hong Kong 07
      - 🇭🇰 Hong Kong 12
      - 🇭🇰 Hong Kong 13
      - 🇭🇰 Hong Kong 18
      - 🇭🇰 Hong Kong 19
    url: http://www.gstatic.com/generate_204
    interval: 120
    lazy: true
    tolerance: 50

  - name: US
    type: url-test
    proxies:
      - 🇺🇸 USA Seattle 09
      - 🇺🇸 USA Seattle 08
      - 🇺🇸 USA Seattle 04
      - 🇺🇸 USA Seattle 03
      - 🇺🇸 USA Seattle 01
      - 🇺🇸 USA Seattle 06
      - 🇺🇸 USA Seattle 02
      - 🇺🇸 USA San Jose 07
      - 🇺🇸 USA Seattle 07
      - 🇺🇸 USA San Jose 08
      - 🇺🇸 USA Los Angeles 01
      - 🇺🇸 USA Los Angeles 03
      - 🇺🇸 USA Seattle 05
      - 🇺🇸 USA Los Angeles 02
      - 🇺🇸 USA Los Angeles 04
      - 🇺🇸 USA Los Angeles 05
      - 🇺🇸 USA Los Angeles 06
      - 🇺🇸 USA Los Angeles 07
    url: http://www.gstatic.com/generate_204
    interval: 120
    lazy: true
    tolerance: 50

  - name: Netflix
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: HBO
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: DisneyPlus
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: YouTube
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: Bahamut
    type: select
    proxies:
      - Proxies
      - HK
      - DIRECT

  - name: Bilibili
    type: select
    proxies:
      - DIRECT
      - Proxies
      - HK

  - name: MyTVSuper
    type: select
    proxies:
      - HK
      - Proxies
      - DIRECT

  - name: Telegram
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

  - name: Crypto
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

  - name: Steam
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

  - name: Epic
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

  - name: Xbox
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

  - name: PlayStation
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

  - name: Microsoft
    type: select
    proxies:
      - DIRECT
      - Proxies
      - US

  - name: Scholar
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: Apple
    type: select
    proxies:
      - DIRECT
      - Proxies
      - HK

  - name: Google
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: Tiktok
    type: select
    proxies:
      - Proxies
      - US
      - HK
      - DIRECT

  - name: 🎯Direct
    type: select
    proxies:
      - DIRECT
      - Proxies

  - name: ✈️Final
    type: select
    proxies:
      - Proxies
      - HK
      - US
      - DIRECT

